[sub_resource type="GDScript" id="GDScript_0bbpv"]
script/source = "extends Node3D

@export var camera: Camera3D

@export var focus_time := 0.25
@export var padding := 1.25
@export var min_dist := 0.6
@export var max_dist := 10.0

# Current distance
var _dist := 3.0
var _tween: Tween

func _ready() -> void:
	if camera == null:
		camera = $Camera3D

	# Initialize distance from current local position
	_dist = -camera.position.z

func focus_on_part(part: Node3D) -> void:
	if part == null: return

	var target_pos := _get_part_focus_position(part)
	var desired_dist := _compute_distance_for_part(part)

	desired_dist = clamp(desired_dist, min_dist, max_dist)

	if _tween and _tween.is_running():
		_tween.kill()

	_tween = create_tween()
	_tween.set_trans(Tween.TRANS_QUAD)
	_tween.set_ease(Tween.EASE_OUT)

	_tween.tween_property(self, \"global_position\", target_pos, focus_time)
	_tween.parallel().tween_method(_set_distance, _dist, desired_dist, focus_time)

func _set_distance(d: float) -> void:
	_dist = d
	camera.position.z = -_dist

func _get_part_focus_position(part: Node3D) -> Vector3:
	var fp := part.get_node_or_null(\"FocusPoint\")
	if fp and fp is Node3D:
		return (fp as Node3D).global_position

	var aabb := _get_global_aabb(part)
	return aabb.get_center()

func _compute_distance_for_part(part: Node3D) -> float:
	var aabb := _get_global_aabb(part)
	var radius := aabb.get_longest_axis_size() * 0.5
	radius = max(radius, 0.05)
	radius *= padding

	return radius * 3.0

func _get_global_aabb(root: Node3D) -> AABB:
	var has_any := false
	var merged := AABB()

	for n in root.get_children(true):
		if n is VisualInstance3D:
			var vi := n as VisualInstance3D
			var local := vi.get_aabb()
			var global := _aabb_transform(local, vi.global_transform)

			if not has_any:
				merged = global
				has_any = true
			else:
				merged = merged.merge(global)

	if not has_any:
		merged = AABB(root.global_position, Vector3.ONE * 0.1)

	return merged

func _aabb_transform(aabb: AABB, t: Transform3D) -> AABB:
	var pts := [
		aabb.position,
		aabb.position + Vector3(aabb.size.x, 0, 0),
		aabb.position + Vector3(0, aabb.size.y, 0),
		aabb.position + Vector3(0, 0, aabb.size.z),
		aabb.position + Vector3(aabb.size.x, aabb.size.y, 0),
		aabb.position + Vector3(aabb.size.x, 0, aabb.size.z),
		aabb.position + Vector3(0, aabb.size.y, aabb.size.z),
		aabb.position + aabb.size
	]

	var p0: Vector3 = t * pts[0]
	var out := AABB(p0, Vector3.ZERO)
	for i in range(1, pts.size()):
		out = out.expand(t * pts[i])
	return out
"

